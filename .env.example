# AWS Bedrock (used by apps/api's Agent)
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_ID=zai.glm-5
BEDROCK_REGION=us-east-1

# Rate limiting on POST /chat (optional — both have working defaults)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

# Shared secret between apps/web and apps/api (optional — unset disables the
# check entirely, so local dev works without it). Not real security, just an
# abuse-deterrent — see packages/config/src/apiKey.ts.
API_KEY=

# Max estimated tokens of conversation history sent to the model before the
# oldest turns get dropped (optional — has a working default).
MAX_CONTEXT_TOKENS=50000

# Notion sync (used only by scripts/sync-notion.ts, never by the running API)
NOTION_API_KEY=
NOTION_ROOT_PAGE_ID=
NOTION_PROJECTS_DATABASE_ID=
